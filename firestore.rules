rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // You, signed in with Google on the admin page. The email_verified check
    // matters: without it, anyone could register an unverified email/password
    // account claiming this address and walk right in.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'nd82soft@gmail.com'
        && request.auth.token.email_verified == true;
    }

    match /events/{code} {
      // Anyone with the album code can open it. Codes are random, so this is
      // link-based privacy. Nobody except the admin can LIST albums, which is
      // what keeps strangers from enumerating everyone's events.
      // Signed-in hosts can list THEIR OWN albums (the query must filter by
      // their hostUid, Firestore enforces that). Only the admin lists all.
      allow get: if true;
      allow list: if isAdmin()
        || (request.auth != null && resource.data.hostUid == request.auth.uid);

      // Only signed-in (anonymous counts) users can create, and the event
      // must belong to them and start unpaid.
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.paid == false
        && request.resource.data.photoCount == 0;

      // Guests may only move the photo counter one step at a time, so nobody
      // can reset it to zero and dodge the free limit. Hosts can edit their
      // event but never their own paid flag. The admin can change anything,
      // which is how the dashboard marks albums paid after Stripe pays out.
      allow update: if isAdmin() || (request.auth != null && (
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoCount'])
          && (
            request.resource.data.photoCount == resource.data.photoCount + 1
            || request.resource.data.photoCount == resource.data.photoCount - 1
          )
        )
        // Vanity counters. Anyone can bump them by one step; worst case is a
        // slightly inflated stat, never anything that touches money or data.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['scanCount'])
          && request.resource.data.scanCount == resource.data.get('scanCount', 0) + 1
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount'])
          && request.resource.data.downloadCount > resource.data.get('downloadCount', 0)
        )
        || (
          resource.data.hostUid == request.auth.uid
          && request.resource.data.paid == resource.data.paid
          && request.resource.data.photoCount == resource.data.photoCount
        )
      ));

      // Hosts can delete their own albums, the admin can delete any.
      allow delete: if isAdmin()
        || (request.auth != null && resource.data.hostUid == request.auth.uid);

      match /photos/{photoId} {
        allow read: if true;

        // Any signed-in guest can add a photo, tagged with their own uid.
        // The free limit is enforced HERE, not just in the browser: unpaid
        // albums stop accepting photos at 25 even if someone calls the
        // Firestore API directly with devtools.
        allow create: if request.auth != null
          && request.resource.data.uploaderUid == request.auth.uid
          && (
            get(/databases/$(database)/documents/events/$(code)).data.paid == true
            || get(/databases/$(database)/documents/events/$(code)).data.photoCount < 25
          );

        allow update: if false;

        // The uploader can remove their own photo. The host can remove any.
        allow delete: if isAdmin() || (request.auth != null && (
          resource.data.uploaderUid == request.auth.uid
          || get(/databases/$(database)/documents/events/$(code)).data.hostUid == request.auth.uid
        ));
      }

      // Guestbook messages. Anyone with the album can read and post. You can
      // delete your own; the host and admin can delete any.
      match /messages/{msgId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if false;
        allow delete: if isAdmin() || (request.auth != null && (
          resource.data.authorUid == request.auth.uid
          || get(/databases/$(database)/documents/events/$(code)).data.hostUid == request.auth.uid
        ));
      }
    }

    // Photo reports. Any signed-in guest can flag a photo. Only the owner
    // reads or clears them, from the HQ dashboard. Nobody can enumerate or
    // edit reports, so they can't be used to snoop or tamper.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, list, delete: if isAdmin();
      allow update: if false;
    }
  }
}
