rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /events/{code}/{fileName} {
      allow read: if true;

      // Signed-in guests only, and the album must exist in Firestore. Images
      // are compressed client-side (~300 KB, 10 MB backstop); videos upload
      // as-is with a 100 MB cap.
      allow create: if request.auth != null
        && firestore.exists(/databases/(default)/documents/events/$(code))
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 100 * 1024 * 1024)
        );

      allow update: if false;

      // Only the admin deletes storage objects. When a host or guest removes
      // a photo, the app deletes the Firestore record (which the gallery is
      // built from) and quietly leaves the file; orphaned files cost nothing
      // meaningful and nobody can reach them without the exact random path.
      allow delete: if request.auth != null
        && request.auth.token.email == 'nd82soft@gmail.com'
        && request.auth.token.email_verified == true;
    }
  }
}
